{
    "name": "scalecommerce/videooptimizer-sulu",
    "description": "Integrates ScaleCommerce VideoOptimizer into the Sulu 3.0 admin: pick, upload and manage CDN-delivered videos without a separate VideoOptimizer login.",
    "type": "sulu-bundle",
    "license": "MIT",
    "keywords": ["sulu", "sulu-bundle", "video", "videooptimizer", "cms", "hls", "cdn"],
    "homepage": "https://videooptimizer.eu/",
    "authors": [
        {
            "name": "ScaleCommerce GmbH",
            "homepage": "https://scale.sc/"
        }
    ],
    "support": {
        "docs": "https://api.videooptimizer.eu/",
        "issues": "https://github.com/scalecommerce/videooptimizer-sulu/issues",
        "source": "https://github.com/scalecommerce/videooptimizer-sulu"
    },
    "require": {
        "php": ">=8.2",
        "ext-sodium": "*",
        "sulu/sulu": "^3.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-client": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "doctrine/orm": "^2.15 || ^3.0",
        "doctrine/dbal": "^3.6 || ^4.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpspec/prophecy-phpunit": "^2.1",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "symfony/cache": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Scale\\VideoOptimizerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scale\\VideoOptimizerBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.2.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
