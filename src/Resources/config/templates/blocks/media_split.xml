<?xml version="1.0" ?>
<type xmlns="http://schemas.sulu.io/template/template" name="vo_media_split">
    <meta>
        <title lang="en">Media split (video + text)</title>
        <title lang="de">Media-Split (Video + Text)</title>
    </meta>
    <properties>
        <property name="video" type="video_optimizer">
            <meta>
                <title lang="en">Video</title>
                <title lang="de">Video</title>
            </meta>
        </property>
        <property name="side" type="single_select">
            <meta>
                <title lang="en">Video side</title>
                <title lang="de">Video-Seite</title>
            </meta>
            <params>
                <param name="default_value" value="left"/>
                <param name="values" type="collection">
                    <param name="left"><meta><title lang="en">Left</title><title lang="de">Links</title></meta></param>
                    <param name="right"><meta><title lang="en">Right</title><title lang="de">Rechts</title></meta></param>
                </param>
            </params>
        </property>
        <property name="eyebrow" type="text_line">
            <meta><title lang="en">Eyebrow</title><title lang="de">Kicker</title></meta>
        </property>
        <property name="headline" type="text_line">
            <meta><title lang="en">Headline</title><title lang="de">Überschrift</title></meta>
        </property>
        <property name="text" type="text_editor">
            <meta><title lang="en">Text</title><title lang="de">Text</title></meta>
        </property>
        <property name="ctaLabel" type="text_line">
            <meta><title lang="en">Button label</title><title lang="de">Button-Text</title></meta>
        </property>
        <property name="ctaUrl" type="text_line">
            <meta><title lang="en">Button URL</title><title lang="de">Button-URL</title></meta>
        </property>
        <property name="presentation" type="single_select">
            <meta><title lang="en">Presentation</title><title lang="de">Darstellung</title></meta>
            <params>
                <param name="default_value" value="facade"/>
                <param name="values" type="collection">
                    <param name="facade"><meta><title lang="en">Thumbnail, load player on click</title><title lang="de">Vorschaubild, Klick lädt Player</title></meta></param>
                    <param name="lightbox"><meta><title lang="en">Thumbnail, open in lightbox</title><title lang="de">Vorschaubild, Lightbox</title></meta></param>
                    <param name="direct"><meta><title lang="en">Embed player directly</title><title lang="de">Player direkt einbetten</title></meta></param>
                </param>
            </params>
        </property>
        <property name="player" type="single_select">
            <meta><title lang="en">Player</title><title lang="de">Player</title></meta>
            <params>
                <param name="default_value" value="inherit"/>
                <param name="values" type="collection">
                    <param name="inherit"><meta><title lang="en">Global default</title><title lang="de">Globaler Standard</title></meta></param>
                    <param name="hosted"><meta><title lang="en">Hosted player (iframe)</title><title lang="de">Gehosteter Player (iframe)</title></meta></param>
                    <param name="native"><meta><title lang="en">Native player</title><title lang="de">Nativer Player</title></meta></param>
                </param>
            </params>
        </property>
        <property name="autoplay" type="single_select">
            <meta><title lang="en">Autoplay</title><title lang="de">Autoplay</title></meta>
            <params>
                <param name="default_value" value="inherit"/>
                <param name="values" type="collection">
                    <param name="inherit"><meta><title lang="en">Theme default</title><title lang="de">Theme-Standard</title></meta></param>
                    <param name="1"><meta><title lang="en">On</title><title lang="de">An</title></meta></param>
                    <param name="0"><meta><title lang="en">Off</title><title lang="de">Aus</title></meta></param>
                </param>
            </params>
        </property>
        <property name="controls" type="single_select">
            <meta><title lang="en">Player controls</title><title lang="de">Player-Bedienelemente</title></meta>
            <params>
                <param name="default_value" value="inherit"/>
                <param name="values" type="collection">
                    <param name="inherit"><meta><title lang="en">Theme default</title><title lang="de">Theme-Standard</title></meta></param>
                    <param name="1"><meta><title lang="en">On</title><title lang="de">An</title></meta></param>
                    <param name="0"><meta><title lang="en">Off</title><title lang="de">Aus</title></meta></param>
                </param>
            </params>
        </property>
        <property name="loop" type="single_select">
            <meta><title lang="en">Loop</title><title lang="de">Endlosschleife</title></meta>
            <params>
                <param name="default_value" value="inherit"/>
                <param name="values" type="collection">
                    <param name="inherit"><meta><title lang="en">Theme default</title><title lang="de">Theme-Standard</title></meta></param>
                    <param name="1"><meta><title lang="en">On</title><title lang="de">An</title></meta></param>
                    <param name="0"><meta><title lang="en">Off</title><title lang="de">Aus</title></meta></param>
                </param>
            </params>
        </property>
        <property name="muted" type="single_select">
            <meta><title lang="en">Muted</title><title lang="de">Stummgeschaltet</title></meta>
            <params>
                <param name="default_value" value="inherit"/>
                <param name="values" type="collection">
                    <param name="inherit"><meta><title lang="en">Theme default</title><title lang="de">Theme-Standard</title></meta></param>
                    <param name="1"><meta><title lang="en">On</title><title lang="de">An</title></meta></param>
                    <param name="0"><meta><title lang="en">Off</title><title lang="de">Aus</title></meta></param>
                </param>
            </params>
        </property>
        <property name="priority" type="checkbox">
            <meta>
                <title lang="en">Prioritize loading (above the fold)</title>
                <title lang="de">Bevorzugt laden (above the fold)</title>
                <info_text lang="en">Enable for the topmost/LCP block: loads its poster eagerly and skips the fade-in.</info_text>
                <info_text lang="de">Für den obersten/LCP-Block aktivieren: lädt das Poster sofort und überspringt die Einblend-Animation.</info_text>
            </meta>
        </property>
    </properties>
</type>
